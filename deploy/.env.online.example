# Public domains (point DNS A records to your VPS)
FRONTEND_DOMAIN=zara.example.com
API_DOMAIN=api.zara.example.com

# Frontend build-time backend URL
VITE_BACKEND_URL=https://api.zara.example.com

# CORS list consumed by backend
CORS_ORIGINS=https://zara.example.com

# MQTT connection used by backend Flight Mode bridge
# Self-hosted profile: keep host=mosquitto and run with --profile selfhosted-mqtt
FLIGHT_MQTT_HOST=mosquitto
FLIGHT_MQTT_PORT=1883
FLIGHT_MQTT_USERNAME=zara
FLIGHT_MQTT_PASSWORD=replace-with-strong-password

# MQTT TLS options (required for managed cloud brokers such as HiveMQ Cloud)
FLIGHT_MQTT_TLS_ENABLED=false
FLIGHT_MQTT_TLS_INSECURE=false
FLIGHT_MQTT_TLS_CA_CERT=
FLIGHT_MQTT_TLS_CERTFILE=
FLIGHT_MQTT_TLS_KEYFILE=

# Published port when using self-hosted Mosquitto profile
MQTT_PUBLIC_PORT=1883
