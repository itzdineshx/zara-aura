# Render production env template for ZARA backend
# Copy values into Render dashboard Environment variables.

APP_NAME=ZARA AI Backend
APP_VERSION=0.1.0
DEFAULT_MODE=smart

# Required secrets
OPENROUTER_API_KEY=replace_me

# Keep TTS off by default for lower memory footprint
TTS_ENABLED=false

# Backend runtime behavior
AUTOMATION_EXECUTE=false
FLIGHT_MODE_DEFAULT=false
PORT=8000
WEB_CONCURRENCY=1

# CORS must include your Vercel production domain
CORS_ORIGINS=https://your-app.vercel.app

# MQTT bridge (use managed broker for internet usage)
FLIGHT_MQTT_ENABLED=true
FLIGHT_MQTT_HOST=your-broker-host
FLIGHT_MQTT_PORT=8883
FLIGHT_MQTT_KEEPALIVE_S=30
FLIGHT_MQTT_CLIENT_ID=zara-backend
FLIGHT_MQTT_USERNAME=your-broker-username
FLIGHT_MQTT_PASSWORD=your-broker-password
FLIGHT_MQTT_TLS_ENABLED=true
FLIGHT_MQTT_TLS_INSECURE=false
FLIGHT_MQTT_TLS_CA_CERT=
FLIGHT_MQTT_TLS_CERTFILE=
FLIGHT_MQTT_TLS_KEYFILE=
FLIGHT_MQTT_CONTROL_TOPIC=zara/flight/control
FLIGHT_MQTT_STATUS_TOPIC=zara/flight/status
FLIGHT_MQTT_QOS=1
FLIGHT_MQTT_RETRY_ATTEMPTS=3
FLIGHT_MQTT_RETRY_DELAY_MS=250
FLIGHT_MQTT_PUBLISH_TIMEOUT_S=1.5
